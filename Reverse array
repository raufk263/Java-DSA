

class test{
    public static void main(String[] args) {
       int arr[]={5,10,20,15};
       int len=arr.length;
        int start=0;
        int end=len-1;
        while(start<end){
            int temp=arr[start];
            arr[start]=arr[end];
            arr[end]=temp;
            start++;
            end--;
        }
       for(int i=0; i<arr.length; i++){
        System.out.print(arr[i]+" ");
       }
    }
}
