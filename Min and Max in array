

class test{
    public static void main(String[] args) {
       int arr[]={1,3,5,2,9,7};
       int min=arr[0],max=arr[arr.length-1];
       for(int i=0; i<arr.length; i++){
        if(arr[i]<min) min=arr[i];
        if(arr[i]>max) max=arr[i];
       }
       System.out.println(max+" "+min);
    }
}
